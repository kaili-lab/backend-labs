{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Maven: debug mall-app",
      "type": "shell",
      "command": "mvn spring-boot:run -pl mall-app -Dspring-boot.run.jvmArguments='-agentlib:jdwp=transport=dt_socket,server=y,suspend=y,address=5004'",
      "options": {
        "cwd": "${workspaceFolder}/labs/web-server-scaling"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": ".*",
          "message": 0
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "Listening for transport dt_socket at address: 5004"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Maven: debug java-concurrency-lab",
      "type": "shell",
      "command": "./mvnw spring-boot:run -Dspring-boot.run.jvmArguments='-agentlib:jdwp=transport=dt_socket,server=y,suspend=y,address=5006'",
      "options": {
        "cwd": "${workspaceFolder}/labs/independent-demos/java-concurrency-lab"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": ".*",
          "message": 0
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "Listening for transport dt_socket at address: 5006"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Maven: test mall-app",
      "type": "shell",
      "command": "mvn test -pl mall-app",
      "options": {
        "cwd": "${workspaceFolder}/labs/web-server-scaling"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Maven: test java-concurrency-lab",
      "type": "shell",
      "command": "./mvnw test",
      "options": {
        "cwd": "${workspaceFolder}/labs/independent-demos/java-concurrency-lab"
      },
      "group": "test",
      "problemMatcher": []
    }
  ]
}
